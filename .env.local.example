# POC 1 — third-party-poc1 configuration
#
# NEXT_PUBLIC_THEME_MODE selects the rebrand mechanism the third party honors:
#   none  - default Forum One brand, no overrides applied
#   json  - load the most recently POSTed DTCG bundle from .data/current-theme.json
#           and emit a <style id="dtcg-theme">:root { ... }</style> in the head
#   link  - inject <link rel="stylesheet" href="$NEXT_PUBLIC_SHELL_BRAND_URL"> in the head
#
# Restart `npm run dev` after changing.
NEXT_PUBLIC_THEME_MODE=none

# Used only when NEXT_PUBLIC_THEME_MODE=link
NEXT_PUBLIC_SHELL_BRAND_URL=http://localhost:3000/brand/overrides.css
